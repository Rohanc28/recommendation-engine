# ── SQLite (demo/local) ───────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./cinematch.db

# ── PostgreSQL (production) — swap above line for this ───────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/moviedb

SECRET_KEY=change-me-in-production-min-32-chars-please!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Enables in-memory embedding + rec caches; skips recomputation on movie update
DEMO_MODE=true

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
EMBEDDING_MODEL=all-MiniLM-L6-v2
